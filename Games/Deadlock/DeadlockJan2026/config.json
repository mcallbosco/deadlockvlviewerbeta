{
  "site": {
    "name": "Deadlock Voice Line Viewer",
    "gameName": "Deadlock",
    "tagline": "An easy-to-browse collection of Deadlock voice lines and conversations",
    "navigation": [
      {
        "href": "/characters",
        "label": "Characters"
      },
      {
        "href": "/conversations",
        "label": "Conversations"
      },
      {
        "href": "/voicelines",
        "label": "Voice Lines"
      }
    ],
    "baseUrl": "https://deadlock.vlviewer.com"
  },
  "homepage": {
    "infoBox": {
      "title": "About This Site",
      "mainDescription": "This site provides an easy way to browse and search through Deadlock's audio content, separated into two categories:",
      "categories": [
        {
          "name": "Conversations",
          "description": "Characters interacting with each other in sequence, forming complete dialogues. These happen at the start of a match."
        },
        {
          "name": "Voice lines",
          "description": "Any voice lines that are not part of conversations. These are organized in a way to try and make it easy to find by character speaking, category, and character the voiceline is referencing."
        }
      ],
      "sections": [
        {
          "title": "Transcription Accuracy",
          "content": "Deadlock now has offical voiceline transcriptions, so most voicelines should have accurate captions. However, some don't, and those are transcribed using Whisper. If you notice any incorrect captions with an edit button, please consider submitting a correction via a pull request to:",
          "link": "https://github.com/mcallbosco/Deadlock-Transcriptions",
          "linkText": "https://github.com/mcallbosco/Deadlock-Transcriptions"
        }
      ],
      "footer": "Browse by character below or use the navigation menu to explore all conversations and voice lines."
    }
  },
  "footer": {
    "mainText": "Deadlock Conversations Viewer",
    "copyright": "Valve, the Valve logo, Steam, the Steam logo, Deadlock, and the Deadlock logo are trademarks and/or registered trademarks of Valve Corporation. Deadlock Conversations Viewer is a fan website and not associated with Valve.",
    "companyLink": "https://www.valvesoftware.com/en/",
    "designCredit": "Designed by Mcall",
    "designerLink": "https://mcallbos.co",
    "donationText": "Buy me a coffee",
    "donationLink": "https://ko-fi.com/mcallbosco",
    "feedbackText": "Leave feedback on my thread in the Deadlock Discord",
    "feedbackLink": "https://discord.com/channels/1231286446472691825/1410736031598121102",
    "resources": [
      {
        "label": "Source 2 Viewer",
        "url": "https://valveresourceformat.github.io/",
        "description": "Explore the game files."
      },
      {
        "label": "Deadlock Wiki",
        "url": "https://deadlock.wiki/",
        "description": "The wiki has some really good documentation on the game in it's current and old state."
      },
      {
        "label": "Neon Prime Voice Lines",
        "url": "https://www.youtube.com/watch?v=kxrf7KplbfU",
        "description": "Voicelines from when Deadlock wasn't deadlock."
      },
      {
        "label": "Neon Prime Music",
        "url": "https://www.youtube.com/watch?v=TCPnNCgqW4Y",
        "description": "Music from Neon Prime"
      }
    ]
  },
  "audioFolder": "Games/Deadlock/DeadlockJan2026/Audio",
  "conversationStyles": ["game-chat"],
  "portraitDirectory": "Games/Deadlock/Icons",
  "voicelineFile": "Games/Deadlock/DeadlockJan2026/all_voicelines.json",
  "conversationsFile": "Games/Deadlock/DeadlockJan2026/all_conversations.json",
  "coverageFile": "Games/Deadlock/DeadlockJan2026/coverage.json",
  "categoriesFile": "Games/Deadlock/DeadlockJan2026/categories.json",
  "localizationDefaultLanguage": "english",
  "showSttLocalizationFallbackIndicator": true,
  "voicelinePlayCounterId": "VLVVLDeadlockPlayed",
  "opengraphIcon": "Games/Deadlock/Icons/deadlock.png",
  "favicon": "Games/Deadlock/Icons/deadlock.ico",
  "faviconPng": "Games/Deadlock/Icons/deadlock.png",
  "appleTouchIcon": "Games/Deadlock/Icons/deadlock.png",
  "ui": {
    "showNewVoicelineIndicators": true,
    "checkboxActiveColor": "#3f795f",
    "showDownloadAllButton": true,
    "downloadButtonColor": "#3f795f",
    "showCharacterNameImages": true
  },
  "events": {
    "definitions": {
      "catlock": {
        "label": "Catlock",
        "description": "April Fools cat-themed text and icons.",
        "textReplacements": [
          { "from": "Deadlock", "to": "Catlock", "excludeFooter": true },
          { "from": "Voice Line Viewer", "to": "Meow Viewer" },
          { "from": "Conversation Viewer", "to": "Bi-Directional Meow Viewer" },
          { "from": "voice lines", "to": "meows" },
          { "from": "Voice Lines", "to": "Meows" },
          { "from": "voicelines", "to": "meows" },
          { "from": "Voicelines", "to": "Meows" },
          { "from": "voice line", "to": "meow" },
          { "from": "Voice Line", "to": "Meow" },
          { "from": "voiceline", "to": "meow" },
          { "from": "Voiceline", "to": "Meow" },
          { "from": "Conversations", "to": "Conpurrsations" },
          { "from": "conversations", "to": "conpurrsations" },
          { "from": "Conversation", "to": "Conpurrsation" },
          { "from": "conversation", "to": "conpurrsation" },
          { "from": "Characters", "to": "Cats" },
          { "from": "characters", "to": "cats" },
          { "from": "Character", "to": "Cat" },
          { "from": "character", "to": "cat" }
        ],
        "iconOverrides": {
          "normalPackId": "catlock",
          "normalVariant": "normal",
          "hoverPackId": "catlock",
          "hoverVariant": "gloat",
          "allowUserOptOut": true
        }
      }
    }
  },
  "iconPacks": {
    "baseDirectory": "Games/Deadlock/DeadlockJan2026/IconPacks",
    "defaultNormalPackId": "default",
    "externalSource": {
      "repo": "mcallbosco/vlviewer-icon-packs",
      "ref": "main",
      "gameDir": "packs/deadlock"
    },
    "families": [
      { "id": "official", "label": "Official" },
      { "id": "event", "label": "Event" }
    ],
    "packs": [
      {
        "id": "default",
        "familyId": "official",
        "manifest": "Games/Deadlock/DeadlockJan2026/IconPacks/default/manifest.json"
      }
    ]
  },
  "modules": {
    "characterCard": "deadlock-blemished-wobbly",
    "enableStaples": true,
    "characterCardVoicelineCard": {
      "module": "voiceline-masked",
      "props": {
        "maskColor": "#2E443D",
        "maskScale": 1.0,
        "edgeScale": 1.5,
        "sideEdgeScale": 1.2
      }
    },
    "characterCardVoicelineStatCards": {
      "module": "voiceline-masked",
      "props": {
        "maskColor": "#39584B"
      }
    },
    "blogBanner": "deadlock-blemished",
    "characterSidebar": "deadlock-blemished",
    "conversationBubbles": {
      "module": "deadlock-blemished"
    },
    "conversationContainer": "transparent",
    "conversationTitle": "transparent"
  },
  "characterSidebarConfig": "Games/Deadlock/character-sidebar-config.json",
  "characterSidebarGlobalStyle": {
    "centered": true,
    "removeBackground": true
  },
  "loadingGif": "Games/Deadlock/Icons/loading.gif",
